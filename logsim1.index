<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>WAR LOGISTICS COMMANDER — LogSim 1 Prototype</title>
<style>
:root{--bg:#040607;--panel:rgba(5,14,18,.92);--cyan:#60ffe3;--red:#ff4747;--green:#68ff95;--yellow:#ffe36b;--orange:#ff9d38;--blue:#7fc7ff;--text:#effffb;--muted:#a7beb9;--line:rgba(96,255,227,.32)}
*{box-sizing:border-box;margin:0;padding:0}
html,body{min-height:100%;background:#020404;color:var(--text);font-family:Arial,Helvetica,sans-serif;overflow-x:hidden}
body:before{content:"";position:fixed;inset:0;z-index:-5;background:radial-gradient(circle at 18% 15%,rgba(255,0,0,.22),transparent 25%),radial-gradient(circle at 85% 88%,rgba(255,140,0,.24),transparent 30%),linear-gradient(rgba(0,0,0,.72),rgba(0,0,0,.94)),url("https://images.unsplash.com/photo-1514924013411-cbf25faa35bb?q=80&w=2070&auto=format&fit=crop") center/cover no-repeat}
body:after{content:"";position:fixed;inset:0;z-index:100;pointer-events:none;background:repeating-linear-gradient(to bottom,rgba(255,255,255,.035) 0px,rgba(255,255,255,.035) 1px,transparent 2px,transparent 7px);opacity:.4}
.fire{position:fixed;left:0;bottom:0;width:100%;height:260px;z-index:-4;background:linear-gradient(to top,rgba(255,55,0,.7),rgba(255,145,0,.23),transparent);animation:fireGlow 1.2s infinite alternate}@keyframes fireGlow{from{opacity:.45}to{opacity:1}}
.shake{animation:shake .13s infinite}@keyframes shake{0%{transform:translate(1px,1px)}25%{transform:translate(-2px,1px)}50%{transform:translate(2px,-1px)}75%{transform:translate(-1px,2px)}100%{transform:translate(1px,-2px)}}
.screen{display:none;min-height:100vh}.screen.active{display:block}
.btn,button{font-family:inherit;cursor:pointer;border:1px solid var(--cyan);background:rgba(96,255,227,.10);color:var(--cyan);padding:12px 15px;border-radius:9px;font-weight:900;transition:.18s}
.btn:hover,button:hover{background:var(--cyan);color:#001b16;transform:translateY(-1px)}
.green{border-color:var(--green)!important;color:var(--green)!important;background:rgba(104,255,149,.12)!important}.green:hover{background:var(--green)!important;color:#001808!important}
.red{border-color:var(--red)!important;color:#ff8888!important;background:rgba(255,71,71,.12)!important}.red:hover{background:var(--red)!important;color:white!important}
.yellow{border-color:var(--yellow)!important;color:var(--yellow)!important;background:rgba(255,227,107,.12)!important}.yellow:hover{background:var(--yellow)!important;color:#1c1500!important}
.orange{border-color:var(--orange)!important;color:var(--orange)!important;background:rgba(255,157,56,.12)!important}.orange:hover{background:var(--orange)!important;color:#190b00!important}
.blue{border-color:var(--blue)!important;color:var(--blue)!important;background:rgba(127,199,255,.12)!important}.blue:hover{background:var(--blue)!important;color:#001320!important}
.btnRow,.buttons{display:flex;gap:9px;flex-wrap:wrap;margin-top:14px}
.start{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:30px;text-align:center}
.startCard{width:min(1050px,96vw);background:rgba(0,0,0,.82);border:1px solid var(--cyan);box-shadow:0 0 48px rgba(96,255,227,.24);border-radius:18px;padding:42px}
.logo{color:#fff0bc;font-size:48px;font-weight:1000;letter-spacing:3px;text-shadow:0 0 15px #000}
.logo span{display:block;color:var(--cyan);font-size:24px;margin-top:10px;text-shadow:0 0 18px var(--cyan)}
.subtitle{color:var(--red);letter-spacing:3px;margin:15px 0 22px;font-weight:900}
.startText{color:#eafffb;line-height:1.75;font-size:18px;max-width:880px;margin:auto}
.devNote{margin-top:22px;background:rgba(255,227,107,.08);border-left:4px solid var(--yellow);padding:14px;text-align:left;line-height:1.6}
.wrap{width:97%;max-width:1600px;margin:auto;padding:18px 0 32px}
.top{text-align:center;padding:16px 0}.top .logo{font-size:34px}
.alert{width:min(1000px,96%);margin:12px auto 0;border:1px solid var(--red);background:rgba(255,0,0,.15);color:#ff9292;padding:11px;border-radius:10px;font-weight:900;animation:blink 1s infinite}@keyframes blink{0%,100%{opacity:1}50%{opacity:.45}}
.panel{background:var(--panel);border:1px solid var(--line);box-shadow:0 0 22px rgba(96,255,227,.10);border-radius:16px;padding:16px;margin-bottom:14px}
.title{color:var(--cyan);font-weight:900;letter-spacing:1.5px;font-size:14px;text-transform:uppercase;margin-bottom:12px}
.stats{display:grid;grid-template-columns:repeat(10,1fr);gap:8px}
.stat{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.16);border-radius:12px;padding:10px;min-height:78px}
.stat span{display:block;color:var(--muted);font-size:10px;letter-spacing:1px;margin-bottom:6px}.stat strong{color:#fff2a8;font-size:23px}
.bar{height:7px;margin-top:8px;background:rgba(255,255,255,.15);border-radius:999px;overflow:hidden}.fill{height:100%;width:50%;background:var(--cyan);transition:.25s}.fill.red{background:var(--red)}.fill.yellow{background:var(--yellow)}.fill.green{background:var(--green)}
.stageTrack{display:grid;grid-template-columns:repeat(5,1fr);gap:8px}.stageBox{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.18);border-radius:12px;text-align:center;padding:12px 6px;color:#bffff1;font-weight:900}.stageBox small{display:block;color:var(--muted);font-size:10px;margin-top:4px}.stageBox.active{color:white;background:rgba(255,71,71,.25);border-color:var(--red);box-shadow:0 0 18px rgba(255,71,71,.35)}.stageBox.done{background:rgba(104,255,149,.13);border-color:var(--green)}
.main{display:grid;grid-template-columns:1.05fr .95fr;gap:15px}.commandTitle{color:#ff7c7c;font-size:24px;font-weight:1000;margin-bottom:10px}.brief{color:#dffff8;line-height:1.6;font-size:16px}
.stageInfo{background:rgba(255,227,107,.07);border-left:4px solid var(--yellow);border-radius:10px;padding:12px;margin:12px 0;line-height:1.55}.stageInfo b{color:var(--cyan)}.stageInfo strong{color:var(--yellow)}
.mission{border-left:4px solid var(--red);background:rgba(255,71,71,.07);border-radius:10px;padding:12px;margin:12px 0;color:#fff3ba;line-height:1.55}.message{min-height:130px;border-left:4px solid var(--red);background:rgba(255,255,255,.05);border-radius:10px;padding:13px;line-height:1.6}.log{height:290px;overflow:auto;font-size:14px;line-height:1.65}.good{color:#78ff9e}.bad{color:#ff7777}.warn{color:#ffe17a}.info{color:#85d9ff}
.windows{display:grid;grid-template-columns:repeat(2,1fr);gap:10px}.mini{background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.16);border-radius:12px;padding:12px;min-height:86px;line-height:1.5}.mini h4{color:var(--yellow);margin-bottom:6px}
.map{height:525px;position:relative;overflow:hidden;border-radius:16px;border:1px solid rgba(255,255,255,.18);background:linear-gradient(rgba(0,0,0,.28),rgba(0,0,0,.82)),url("https://images.unsplash.com/photo-1508615070457-7baeba4003ab?q=80&w=2070&auto=format&fit=crop") center/cover no-repeat}
.map:before{content:"";position:absolute;inset:0;background:linear-gradient(rgba(96,255,227,.08) 1px,transparent 1px),linear-gradient(90deg,rgba(96,255,227,.08) 1px,transparent 1px);background-size:46px 46px}
.unit{position:absolute;z-index:3;background:rgba(0,0,0,.78);border:1px solid rgba(255,255,255,.45);border-radius:10px;padding:9px 11px;font-weight:900;font-size:13px}.signal{top:14px;left:14px;border-color:var(--red);color:#ff8585;animation:blink 1s infinite}.base{left:7%;bottom:45px;border-color:var(--cyan)}.convoy{left:29%;bottom:55px;border-color:var(--yellow)}.frontline{right:8%;bottom:70px;border-color:var(--green)}.enemy{right:12%;top:110px;border-color:var(--red)}.heli{left:40%;top:76px;border-color:var(--cyan);animation:fly 2.5s infinite alternate}.tank{right:30%;bottom:145px;border-color:var(--orange)}
.boom{position:absolute;right:30%;bottom:120px;font-size:64px;z-index:2;animation:boom .8s infinite alternate}.weather{position:absolute;inset:0;opacity:0;background:radial-gradient(circle,rgba(255,255,255,.32),transparent 60%);transition:.2s}.weather.active{opacity:1}@keyframes fly{from{transform:translateY(0)}to{transform:translateY(-24px)}}@keyframes boom{from{transform:scale(.75);opacity:.4}to{transform:scale(1.35);opacity:1}}.convoy.run{animation:runConvoy 1.7s ease-in-out}@keyframes runConvoy{0%{left:12%;bottom:55px}50%{left:48%;bottom:88px}100%{left:78%;bottom:70px}}
.modal{position:fixed;inset:0;z-index:300;background:rgba(0,0,0,.82);display:none;align-items:center;justify-content:center;padding:22px}.modal.active{display:flex}.modalCard{width:min(900px,96vw);max-height:86vh;overflow:auto;background:rgba(1,10,13,.97);border:1px solid var(--cyan);box-shadow:0 0 35px rgba(96,255,227,.28);border-radius:18px;padding:25px}.modalCard h2{color:var(--cyan);margin-bottom:12px}.modalCard p,.modalCard li{line-height:1.65;color:#eafffb}.modalCard table{width:100%;border-collapse:collapse;margin-top:12px}.modalCard th,.modalCard td{border:1px solid rgba(255,255,255,.18);padding:10px;text-align:left}.modalCard th{color:var(--yellow)}
@media(max-width:1150px){.main{grid-template-columns:1fr}.stats{grid-template-columns:repeat(2,1fr)}.stageTrack,.windows{grid-template-columns:1fr}.logo{font-size:36px}}
</style>
</head>
<body>
<div class="fire"></div>
<div class="modal" id="modal"><div class="modalCard"><h2 id="modalTitle">Window</h2><div id="modalBody"></div><div class="btnRow"><button class="btn green" onclick="closeModal()">Close Window</button></div></div></div>
<section class="screen active start" id="startScreen"><div class="startCard"><div class="logo">WAR LOGISTICS COMMANDER <span>LOGSIM 1 — PROTOTYPE 1</span></div><div class="subtitle">SINGLE FRONTLINE SUPPLY MISSION</div><div class="startText">This is the first prototype of the final logistics simulation game. The player supports one frontline by moving through five connected logistics stages. The numbers carry forward from stage to stage: budget, food, fuel, ammo, medical supplies, morale, base health, convoy health, and score.</div><div class="devNote"><b>Development purpose:</b> LogSim 1 tests the basic connected game loop: Procurement → Storage → Transportation Planning → Transportation/Distribution → Feedback. Later prototypes add multiple frontlines, forecast, crisis, and upgrades.</div><div class="btnRow" style="justify-content:center"><button class="btn blue" onclick="openStageGuide()">Open Stage Guide</button><button class="btn green" onclick="startGame()">START LOGSIM 1</button></div></div></section>
<section class="screen" id="gameScreen"><div class="wrap"><div class="top"><div class="logo">WAR LOGISTICS COMMANDER <span>LOGSIM 1</span></div><div class="alert">WARZONE LIVE — SINGLE FRONTLINE REQUESTING SUPPORT</div></div>
<div class="panel"><div class="stats">
<div class="stat"><span>FOOD</span><strong id="food">50</strong><div class="bar"><div id="foodBar" class="fill"></div></div></div><div class="stat"><span>FUEL</span><strong id="fuel">50</strong><div class="bar"><div id="fuelBar" class="fill"></div></div></div><div class="stat"><span>AMMO</span><strong id="ammo">50</strong><div class="bar"><div id="ammoBar" class="fill"></div></div></div><div class="stat"><span>MEDICAL</span><strong id="medical">50</strong><div class="bar"><div id="medicalBar" class="fill"></div></div></div><div class="stat"><span>BUDGET</span><strong id="budget">100</strong><div class="bar"><div id="budgetBar" class="fill yellow"></div></div></div><div class="stat"><span>MORALE</span><strong id="morale">75</strong><div class="bar"><div id="moraleBar" class="fill green"></div></div></div><div class="stat"><span>BASE</span><strong id="base">100</strong><div class="bar"><div id="baseBar" class="fill"></div></div></div><div class="stat"><span>CONVOY</span><strong id="convoy">100</strong><div class="bar"><div id="convoyBar" class="fill"></div></div></div><div class="stat"><span>SCORE</span><strong id="score">0</strong><div class="bar"><div id="scoreBar" class="fill green"></div></div></div><div class="stat"><span>OP</span><strong id="round">1/5</strong><div class="bar"><div id="roundBar" class="fill green"></div></div></div>
</div></div>
<div class="panel"><div class="stageTrack"><div class="stageBox active" id="stage1">1 PROCUREMENT<small>buy supplies</small></div><div class="stageBox" id="stage2">2 STORAGE<small>protect depot</small></div><div class="stageBox" id="stage3">3 PLANNING<small>route + transport</small></div><div class="stageBox" id="stage4">4 DISTRIBUTION<small>launch convoy</small></div><div class="stageBox" id="stage5">5 FEEDBACK<small>report + next op</small></div></div></div>
<div class="main"><div><div class="panel"><div class="commandTitle" id="phaseTitle">Stage 1 — Procurement</div><div class="brief" id="brief">Buy supplies for one frontline with limited budget.</div><div class="stageInfo" id="stageInfo"></div><div class="mission" id="mission"></div><div class="buttons" id="buttons"></div></div><div class="panel"><div class="title">Simulation Windows</div><div class="windows"><div class="mini"><h4>Current Stage</h4><div id="currentStageWindow"></div></div><div class="mini"><h4>Carried Information</h4><div id="carryWindow"></div></div><div class="mini"><h4>Plan Window</h4><div id="planWindow"></div></div><div class="mini"><h4>Risk Window</h4><div id="riskWindow"></div></div></div></div><div class="panel"><div class="title">Mission Message</div><div class="message" id="message">Command terminal online.</div></div><div class="panel"><div class="title">Operations Log</div><div class="log" id="log">System initialized.</div></div></div><div><div class="panel"><div class="title">Tactical Map</div><div class="map"><div class="unit signal" id="signal">ENEMY SCAN ACTIVE</div><div class="unit base">BASE DEPOT</div><div class="unit convoy" id="convoyIcon">CONVOY</div><div class="unit frontline">FRONTLINE</div><div class="unit enemy">ENEMY ZONE</div><div class="unit heli">AIR SUPPORT</div><div class="unit tank">TANK UNIT</div><div class="boom">💥</div><div class="weather" id="weather"></div></div></div><div class="panel"><div class="title">LogSim 1 Development Focus</div><div class="message"><b>Main focus:</b> Simple connected logistics loop.<br><br><b>Scenario:</b> One frontline needs supplies while enemy pressure increases.<br><br><b>What this prototype teaches:</b> basic resource management, route choice, risk handling, and feedback.</div><div class="btnRow"><button class="btn blue" onclick="openStageGuide()">Open Stage Guide</button></div></div></div></div></div></section>
<script>
let food=50,fuel=50,ammo=50,medical=50,budget=100,morale=75,base=100,convoy=100,score=0;
let round=1,maxRound=5,stage=1,gameOver=false;
let demand={food:20,fuel:15,ammo:18,medical:10};
let completed={1:false,2:false,3:false,4:false,5:false};
let depot="",route="",transport="",result="PENDING";
let depotProtection=0,routeRisk=0,routeFuel=0,transportRisk=0,transportFuel=0,transportCost=0,transportPower=0;
const stageInfo={1:["Procurement","The player collects/buys supplies before the operation.","Buy food, fuel, ammo, and medical supplies with limited budget."],2:["Storage","The supplies from Stage 1 are stored and protected.","Choose depot protection. Weak storage can damage supplies before convoy starts."],3:["Transportation Planning","The player uses remaining supplies and budget to plan movement.","Choose route and transport method. Safe route costs more fuel, risky route may damage convoy."],4:["Transportation / Distribution","The player sends the convoy to the frontline.","Random events can happen: ambush, weather delay, or depot strike."],5:["Feedback / Evaluation","The player reviews result and adjusts next strategy.","Read report, score, morale, remaining resources, then continue to next operation."]};
function startGame(){document.getElementById("startScreen").classList.remove("active");document.getElementById("gameScreen").classList.add("active");newOperation();renderProcurement();updateUI();addLog("LogSim 1 prototype started. Operation 1 active.","warn")}
function randomInt(min,max){return min+Math.floor(Math.random()*(max-min+1))}
function newOperation(){demand.food=randomInt(12,26);demand.fuel=randomInt(10,22);demand.ammo=randomInt(12,28);demand.medical=randomInt(7,18)}
function clamp(){food=Math.max(0,food);fuel=Math.max(0,fuel);ammo=Math.max(0,ammo);medical=Math.max(0,medical);budget=Math.max(0,budget);morale=Math.max(0,Math.min(100,morale));base=Math.max(0,Math.min(100,base));convoy=Math.max(0,Math.min(100,convoy));score=Math.max(0,score)}
function bar(id,value,max=100){const el=document.getElementById(id);const pct=Math.max(0,Math.min(100,(value/max)*100));el.style.width=pct+"%";el.classList.remove("red","yellow","green");if(pct<30)el.classList.add("red");else if(pct<60)el.classList.add("yellow");else el.classList.add("green")}
function updateUI(){clamp();["food","fuel","ammo","medical","budget","morale","base","convoy","score"].forEach(id=>document.getElementById(id).innerText=eval(id));document.getElementById("round").innerText=round+"/"+maxRound;bar("foodBar",food,140);bar("fuelBar",fuel,140);bar("ammoBar",ammo,140);bar("medicalBar",medical,140);bar("budgetBar",budget,140);bar("moraleBar",morale);bar("baseBar",base);bar("convoyBar",convoy);bar("scoreBar",score,300);bar("roundBar",round,maxRound);for(let i=1;i<=5;i++){const el=document.getElementById("stage"+i);el.classList.remove("active","done");if(i===stage)el.classList.add("active");if(completed[i])el.classList.add("done")}updateWindows()}
function message(t){document.getElementById("message").innerHTML=t}function mission(t){document.getElementById("mission").innerHTML=t}function buttons(h){document.getElementById("buttons").innerHTML=h}
function addLog(t,type="info"){const cls=type==="good"?"good":type==="bad"?"bad":type==="warn"?"warn":"info";document.getElementById("log").innerHTML="<div class='"+cls+"'>▸ "+t+"</div>"+document.getElementById("log").innerHTML}
function alarm(t){document.getElementById("signal").innerHTML=t;document.body.classList.add("shake");document.getElementById("weather").classList.add("active");setTimeout(()=>{document.getElementById("signal").innerHTML="ENEMY SCAN ACTIVE";document.body.classList.remove("shake");document.getElementById("weather").classList.remove("active")},2200)}
function updateStageInfo(){const s=stageInfo[stage];document.getElementById("stageInfo").innerHTML="<b>Stage "+stage+": "+s[0]+"</b><br><strong>Logistics meaning:</strong> "+s[1]+"<br><strong>Game task:</strong> "+s[2]}
function updateWindows(){const s=stageInfo[stage];document.getElementById("currentStageWindow").innerHTML="<b>Stage "+stage+": "+s[0]+"</b><br>"+s[1];document.getElementById("carryWindow").innerHTML="Food: <b>"+food+"</b> | Fuel: <b>"+fuel+"</b><br>Ammo: <b>"+ammo+"</b> | Medical: <b>"+medical+"</b><br>Budget: <b>"+budget+"</b> | Morale: <b>"+morale+"</b>";document.getElementById("planWindow").innerHTML="Depot: <b>"+(depot||"Not selected")+"</b><br>Route: <b>"+(route||"Not selected")+"</b><br>Transport: <b>"+(transport||"Not selected")+"</b>";document.getElementById("riskWindow").innerHTML="Depot protection: <b>"+Math.round(depotProtection*100)+"%</b><br>Route risk: <b>"+Math.round((routeRisk+transportRisk)*100)+"%</b><br>Result: <b>"+result+"</b>"}
function openModal(t,b){document.getElementById("modalTitle").innerHTML=t;document.getElementById("modalBody").innerHTML=b;document.getElementById("modal").classList.add("active")}function closeModal(){document.getElementById("modal").classList.remove("active")}
function openStageGuide(){openModal("LogSim 1 Stage Guide",`<p>This is Prototype 1 of the final connected game. It tests the basic five-stage logistics loop.</p><table><tr><th>Stage</th><th>Concept</th><th>In the game</th></tr><tr><td>1</td><td>Procurement</td><td>Buy food, fuel, ammo, and medical supplies.</td></tr><tr><td>2</td><td>Storage</td><td>Choose depot protection for the supplies.</td></tr><tr><td>3</td><td>Transportation Planning</td><td>Choose route and transport method.</td></tr><tr><td>4</td><td>Transportation / Distribution</td><td>Launch the convoy and face random events.</td></tr><tr><td>5</td><td>Feedback / Evaluation</td><td>Read report, score, and continue to the next operation.</td></tr></table>`)}
function renderProcurement(){stage=1;completed={1:false,2:false,3:false,4:false,5:false};depot="";route="";transport="";result="PENDING";depotProtection=0;routeRisk=0;routeFuel=0;transportRisk=0;transportFuel=0;transportCost=0;transportPower=0;document.getElementById("phaseTitle").innerText="Stage 1 — Procurement";document.getElementById("brief").innerText="Buy supplies for one frontline with limited budget.";mission("Frontline demand: Food "+demand.food+" | Fuel "+demand.fuel+" | Ammo "+demand.ammo+" | Medical "+demand.medical);buttons(`<button onclick="buy('food')">Food +12 ($10)</button><button onclick="buy('fuel')">Fuel +12 ($10)</button><button onclick="buy('ammo')">Ammo +12 ($10)</button><button onclick="buy('medical')">Medical +12 ($10)</button><button class="green" onclick="renderStorage()">Confirm Procurement</button>`);message("Choose what to buy. If you spend everything now, later stages may be harder.");updateStageInfo();updateUI()}
function buy(type){if(gameOver||stage!==1)return;if(budget<10){message("Budget is too low. Confirm procurement with current supplies.");return}if(type==="food"){food+=12;message("Food crates purchased.")}if(type==="fuel"){fuel+=12;message("Fuel drums purchased.")}if(type==="ammo"){ammo+=12;message("Ammo cases purchased.")}if(type==="medical"){medical+=12;message("Medical kits purchased.")}budget-=10;addLog(type+" purchased in procurement stage.");updateUI()}
function renderStorage(){completed[1]=true;stage=2;document.getElementById("phaseTitle").innerText="Stage 2 — Storage";document.getElementById("brief").innerText="Protect the supplies bought in Stage 1 before the convoy leaves.";mission("Enemy drones may hit the depot. Stronger storage costs more but protects the cargo.");buttons(`<button onclick="selectDepot('Field Depot')">Field Depot (Free)</button><button class="yellow" onclick="selectDepot('Reinforced Warehouse')">Reinforced Warehouse ($20)</button><button class="green" onclick="selectDepot('Underground Bunker')">Underground Bunker ($35)</button><button class="green" onclick="storageCheck()">Lock Storage</button>`);message("Choose storage. The same supplies from Stage 1 are now at risk.");addLog("Stage 2 opened. Supplies carried from procurement to storage.","warn");updateStageInfo();updateUI()}
function selectDepot(option){if(stage!==2)return;if(option==="Field Depot"){depot=option;depotProtection=.12;message("Field Depot selected. Free but vulnerable.")}if(option==="Reinforced Warehouse"){if(budget<20){message("Not enough budget for reinforced warehouse.");return}budget-=20;depot=option;depotProtection=.42;message("Reinforced Warehouse selected. Medium protection.")}if(option==="Underground Bunker"){if(budget<35){message("Not enough budget for underground bunker.");return}budget-=35;depot=option;depotProtection=.70;message("Underground Bunker selected. Strong protection.")}addLog("Storage selected: "+depot+".");updateUI()}
function storageCheck(){if(!depot){message("Choose storage first.");return}if(Math.random()>depotProtection+.48){base-=12;food-=5;fuel-=5;ammo-=5;alarm("DEPOT STRUCK");message("Enemy drone hit the depot. Some supplies were lost before transportation planning.");addLog("Storage failure: depot attack damaged supplies.","bad")}else{score+=15;message("Storage secured. Supplies protected and ready for route planning.");addLog("Storage success. Supplies protected.","good")}updateUI();checkGame();if(!gameOver)renderPlanning()}
function renderPlanning(){completed[2]=true;stage=3;document.getElementById("phaseTitle").innerText="Stage 3 — Transportation Planning";document.getElementById("brief").innerText="Use remaining supplies and budget to choose route and transport.";mission("Route choice changes risk and fuel use. Transport choice changes cost and protection.");buttons(`<button class="green" onclick="selectRoute('Safe Road')">Safe Road</button><button class="yellow" onclick="selectRoute('Fast Highway')">Fast Highway</button><button class="red" onclick="selectRoute('Hot Zone Shortcut')">Hot Zone Shortcut</button><button onclick="selectTransport('Truck Convoy')">Truck Convoy</button><button class="yellow" onclick="selectTransport('Armored Convoy')">Armored Convoy ($20)</button><button class="green" onclick="selectTransport('Helicopter Drop')">Helicopter Drop ($30)</button><button class="green" onclick="renderDistribution()">Deploy Plan</button>`);message("Choose one route and one transport method. Stage 3 uses what remained from Stage 1 and Stage 2.");addLog("Stage 3 opened. Remaining supplies and budget carried into planning.","warn");updateStageInfo();updateUI()}
function selectRoute(option){route=option;if(option==="Safe Road"){routeRisk=.15;routeFuel=18;message("Safe Road selected. Lower risk but more fuel.")}if(option==="Fast Highway"){routeRisk=.32;routeFuel=20;message("Fast Highway selected. Balanced but still risky.")}if(option==="Hot Zone Shortcut"){routeRisk=.55;routeFuel=12;message("Hot Zone Shortcut selected. Saves fuel but very risky.")}addLog("Route selected: "+route+".");updateUI()}
function selectTransport(option){transport=option;if(option==="Truck Convoy"){transportCost=0;transportRisk=.08;transportFuel=0;transportPower=5;message("Truck Convoy selected. Free but exposed.")}if(option==="Armored Convoy"){if(budget<20){message("Not enough budget for armored convoy.");return}transportCost=20;transportRisk=-.15;transportFuel=10;transportPower=8;message("Armored Convoy selected. Safer but expensive.")}if(option==="Helicopter Drop"){if(budget<30){message("Not enough budget for helicopter drop.");return}transportCost=30;transportRisk=-.12;transportFuel=22;transportPower=9;message("Helicopter Drop selected. Fast but fuel-heavy.")}addLog("Transport selected: "+transport+".");updateUI()}
function renderDistribution(){if(!route||!transport){message("Choose route and transport first.");return}if(budget<transportCost){message("Not enough budget for this transport.");return}budget-=transportCost;completed[3]=true;stage=4;document.getElementById("phaseTitle").innerText="Stage 4 — Transportation / Distribution";document.getElementById("brief").innerText="Launch the convoy and deliver supplies to the frontline.";mission("Plan: "+route+" + "+transport+". Convoy will face random battlefield events.");buttons(`<button class="red" onclick="launchConvoy()">Launch Convoy</button>`);message("Convoy is waiting at the base gate. Stage 4 uses the plan from Stage 3.");addLog("Stage 4 opened. Convoy ready.","warn");updateStageInfo();updateUI()}
function launchConvoy(){if(stage!==4||gameOver)return;let icon=document.getElementById("convoyIcon");icon.classList.remove("run");void icon.offsetWidth;icon.classList.add("run");let match=0;if(food>=demand.food)match++;if(fuel>=demand.fuel)match++;if(ammo>=demand.ammo)match++;if(medical>=demand.medical)match++;food-=Math.ceil(demand.food*.60);fuel-=routeFuel+transportFuel;ammo-=Math.ceil(demand.ammo*.62);medical-=Math.ceil(demand.medical*.55);let finalRisk=Math.max(.05,routeRisk+transportRisk);let roll=Math.random();if(roll<finalRisk){morale-=18;convoy-=18;ammo-=8;medical-=6;result="DAMAGED";alarm("CONVOY AMBUSHED");message("Convoy was ambushed. Some cargo reached, but losses were heavy.");addLog("Convoy ambush. Distribution stage damaged resources.","bad")}else if(roll<finalRisk+.22){morale-=6;fuel-=7;result="DELAYED";alarm("ROUTE DELAY");message("Bad weather delayed delivery. Frontline still received some supplies.");addLog("Route delay during distribution.","warn")}else{morale+=10+match+transportPower;convoy+=3;score+=30+(match*8)+transportPower;result="SUCCESS";message("Convoy delivered supplies. Frontline morale improved.");addLog("Delivery success to frontline.","good")}if(match<3){morale-=8;score-=5;addLog("Cargo did not fully match frontline demand.","warn")}updateUI();checkGame();if(!gameOver)renderFeedback()}
function renderFeedback(){completed[4]=true;stage=5;document.getElementById("phaseTitle").innerText="Stage 5 — Feedback / Evaluation";document.getElementById("brief").innerText="Review outcome. Then carry remaining information to the next operation.";mission("Delivery result: <b>"+result+"</b>");buttons(`<button class="blue" onclick="openReport()">Open Report</button><button class="green" onclick="nextOperation()">Next Operation</button>`);message("Feedback stage active. This report decides how you adjust the next operation.");addLog("Stage 5 opened. Report ready.","warn");updateStageInfo();updateUI()}
function openReport(){completed[5]=true;let report="<b>OPERATION "+round+" REPORT</b><br><br>";report+="Demand: Food "+demand.food+" | Fuel "+demand.fuel+" | Ammo "+demand.ammo+" | Medical "+demand.medical+"<br>";report+="Depot: "+depot+"<br>Route: "+route+"<br>Transport: "+transport+"<br>Result: "+result+"<br><br>";report+="<b>Carried to next operation:</b><br>Food "+food+", Fuel "+fuel+", Ammo "+ammo+", Medical "+medical+", Budget "+budget+", Morale "+morale+", Base "+base+", Convoy "+convoy+", Score "+score+"<br><br>";report+="<b>5-stage connection proof:</b><br>Stage 1 supplies moved into Stage 2 storage. Stage 2 result affected Stage 3 planning. Stage 3 plan affected Stage 4 convoy. Stage 4 result is evaluated in Stage 5.";message(report);addLog("Report opened. Feedback reviewed.","info");updateUI()}
function nextOperation(){if(stage!==5||gameOver)return;if(round>=maxRound){winGame();return}round++;budget+=45;food-=5;fuel-=5;ammo-=5;medical-=3;convoy=Math.min(100,convoy+4);newOperation();renderProcurement();message("New operation started. Remaining information carried forward.");addLog("Operation "+round+" opened. Previous resources carried forward.","warn");updateUI();checkGame()}
function checkGame(){if(food<=0)return loseGame("Food supply collapsed.");if(fuel<=0)return loseGame("Fuel supply collapsed. Convoys cannot move.");if(ammo<=0)return loseGame("Ammo supply collapsed. Frontline cannot defend.");if(medical<=0)return loseGame("Medical supply collapsed.");if(morale<=0)return loseGame("Troop morale collapsed.");if(base<=0)return loseGame("Base depot destroyed.");if(convoy<=0)return loseGame("Convoy destroyed.")}
function loseGame(reason){gameOver=true;alarm("MISSION FAILED");message("<b>MISSION FAILED</b><br><br>"+reason+"<br><br>You reached Operation "+round+" of "+maxRound+".");buttons(`<button class="red" onclick="location.reload()">Restart LogSim 1</button>`);addLog("Mission failed: "+reason,"bad")}
function winGame(){gameOver=true;message("<b>LOGSIM 1 COMPLETE</b><br><br>You completed all 5 operations and kept the frontline supplied.<br><br>Final score: "+score+"<br>Final morale: "+morale+"<br><br>This prototype proves the basic five-stage logistics loop works.");buttons(`<button class="green" onclick="location.reload()">Play Again</button>`);addLog("LogSim 1 completed successfully.","good")}
</script>
</body>
</html>
